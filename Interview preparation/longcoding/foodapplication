  food(int food_id,String food_name,String food_style,double price) {
    this.food_id=food_id;
    this.food_name=food_name;
    this.food_style=food_style;
    this.price=price;
  }
  void displayfood() {
    System.out.println("FoodId"+" "+food_id);
    System.out.println("FoodName"+" "+food_name);
    System.out.println("FoodStyle"+" "+food_style);
    System.out.println("Price"+" "+price);

  }
  static void display3() {
    System.out.println("Pizza");
    System.out.println("Burger");
    System.out.println("Sphagetti");
    System.out.println("Cake");
    System.out.println("Shawarma");
  }
  static  void Available(ArrayList<food>foodlist) {
    Scanner s=new Scanner (System.in);
    System.out.println("Enter your Food name");
    String fooditem=s.nextLine();
    boolean found=false;
    for(food f:foodlist) {
      if(f.food_name.equalsIgnoreCase(fooditem)) {
        System.out.println("Food Available");
        f.displayfood();
        found=true;
        break;
      }
    }
    if(!found) {
      System.out.println("Food not Available");
    }
  }
}
